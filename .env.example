# Quant Research Lab Environment Configuration
# Copy this file to .env and fill in your values

# Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=bot2
MYSQL_PASSWORD=bot2_123456
MYSQL_DATABASE=quant_research

# Binance API (Get from https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Bybit API (Get from https://www.bybit.com/app/user/api-management)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Trading Settings
TRADING_MODE=paper
DEFAULT_SYMBOL=ETHUSDT
INITIAL_CAPITAL=10000
MAX_POSITION=1.0

# Data Download Settings
START_DATE=2024-01-01
END_DATE=2024-12-31
